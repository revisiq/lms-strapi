{
  "kind": "collectionType",
  "collectionName": "questions",
  "info": {
    "singularName": "question",
    "pluralName": "questions",
    "displayName": "Question",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "question": {
      "type": "string",
      "required": true,
      "maxLength": 1000
    },
    "answer": {
      "type": "text",
      "maxLength": 180
    },
    "hint": {
      "type": "string",
      "maxLength": 140
    },
    "example": {
      "type": "string",
      "maxLength": 150
    },
    "decks": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::deck.deck",
      "inversedBy": "questions"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "questions"
    },
    "explanation": {
      "type": "string",
      "maxLength": 400
    },
    "difficulty": {
      "type": "enumeration",
      "enum": ["easy", "medium", "hard"],
      "required": true,
      "default": "medium"
    },
    "type": {
      "type": "enumeration",
      "enum": ["MCQ", "RC", "Parajumble", "Syllogism", "SentenceCompletion", "Other"],
      "default": "MCQ",
      "required": true
    },
    "options": {
      "type": "json"
    },
    "question_group": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::question-group.question-group",
      "inversedBy": "questions"
    }
  }
}
